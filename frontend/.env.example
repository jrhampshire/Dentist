# =============================================================================
# ClínicaSaaS Dental MX — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# Variables prefixed with VITE_ are exposed to the client-side bundle.
# Never put secrets here — only public configuration.
# =============================================================================

# API base URL (without trailing /api/v1)
# For Docker: http://nginx/api/v1
# For local dev: http://localhost:8000/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket URL (for future real-time features)
# For Docker: ws://nginx/ws
# For local dev: ws://localhost:8000/ws
VITE_WS_URL=ws://localhost:8000/ws
