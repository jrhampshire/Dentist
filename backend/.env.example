# =============================================================================
# ClínicaSaaS Dental MX — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# For Docker Compose: variables are passed via docker-compose.yml.
# For local development: set these in your shell or .env file.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Debug mode (set to false in production)
DEBUG=true

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# For Docker: postgresql://dentist:dentist@postgres:5432/clinica_dental
# For local:  postgresql://dentist:dentist@localhost:5432/dentist_dev
DATABASE_URL=postgresql://dentist:dentist@localhost:5432/dentist_dev

# Individual vars (alternative to DATABASE_URL)
POSTGRES_DB=dentist_dev
POSTGRES_USER=dentist
POSTGRES_PASSWORD=dentist
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis (Celery broker + cache)
# ---------------------------------------------------------------------------
# For Docker: redis://redis:6379/0
# For local:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SIGNING_KEY=change-me-to-a-different-long-random-string

# Access token expiry (in seconds, default: 3600 = 1 hour)
JWT_ACCESS_TOKEN_LIFETIME=3600

# Refresh token expiry (in seconds, default: 604800 = 7 days)
JWT_REFRESH_TOKEN_LIFETIME=604800

# ---------------------------------------------------------------------------
# Encryption (NOM-024 — AES-256-GCM key, 32 bytes base64 encoded)
# ---------------------------------------------------------------------------
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@clinicasaas.mx

# ---------------------------------------------------------------------------
# Twilio (WhatsApp Notifications)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---------------------------------------------------------------------------
# Finkok (CFDI 4.0 Stamping)
# ---------------------------------------------------------------------------
FINKOK_USERNAME=
FINKOK_PASSWORD=
FINKOK_SANDBOX=true

# ---------------------------------------------------------------------------
# MinIO / S3 (Optional — for media file storage in production)
# ---------------------------------------------------------------------------
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET_NAME=clinica-dental
# MINIO_USE_SSL=false

# ---------------------------------------------------------------------------
# Sentry (Production monitoring — optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# CORS (comma-separated origins, no spaces)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
# Task queue broker (same as REDIS_URL for Docker)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
